# Template for environment variables. Copy to .env and fill in real values:
#   cp .env.example .env
# This file IS committed; .env is NOT.

POSTGRES_DB=loop
POSTGRES_USER=loop_user
POSTGRES_PASSWORD=change_me
POSTGRES_PORT=5432

DATABASE_URL=postgresql://loop_user:change_me@localhost:5432/loop

# Anthropic API key from https://console.anthropic.com (starts with "sk-ant-").
ANTHROPIC_API_KEY=sk-ant-your-key-here