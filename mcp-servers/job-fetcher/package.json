{
  "name": "job-fetcher-mcp",
  "version": "1.0.0",
  "description": "A standalone MCP server exposing a single tool, fetch_job_posting, that fetches a URL and returns clean text.",
  "private": true,
  "type": "module",
  "bin": {
    "job-fetcher-mcp": "./dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "inspect": "mcp-inspector tsx src/index.ts",
    "test:client": "tsx src/test-client.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.19.1",
    "html-to-text": "^10.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@modelcontextprotocol/inspector": "^0.16.2",
    "@types/html-to-text": "^9.0.4",
    "@types/node": "^22",
    "tsx": "^4.23.0",
    "typescript": "^5"
  }
}
